rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDoc() {
      return get(userDocPath());
    }

    function userExists() {
      return isSignedIn() && exists(userDocPath());
    }

    function isActive() {
      return userExists() && userDoc().data.isActive == true;
    }

    function userRole() {
      return userExists() ? userDoc().data.role : null;
    }

    function isSuperAdmin() {
      return userRole() == 'SUPER_ADMIN';
    }

    function membership(schoolId) {
      return userExists() && userDoc().data.schoolMemberships[schoolId] != null
        ? userDoc().data.schoolMemberships[schoolId]
        : null;
    }

    function isSchoolMember(schoolId) {
      return isActive() && membership(schoolId) != null && membership(schoolId).isActive == true;
    }

    function schoolRole(schoolId) {
      return isSchoolMember(schoolId) ? membership(schoolId).role : null;
    }

    function canManageSchool(schoolId) {
      return isSuperAdmin() || schoolRole(schoolId) in ['MANAGEMENT', 'PRINCIPAL'];
    }

    function canWriteAcademicRecords(schoolId) {
      return canManageSchool(schoolId) || schoolRole(schoolId) in ['TEACHER', 'STAFF'];
    }

    function canReadSchoolPath(schoolId, collectionName) {
      return isSchoolMember(schoolId)
        && (
          collectionName in ['students', 'teachers', 'staff', 'classes', 'attendance', 'homework', 'results', 'announcements', 'read_models', 'results_finalization', 'payroll', 'critical_attendance_overrides', 'parent_links', 'notification_queue']
        );
    }

    function isParentLinkedToStudent(schoolId, studentUid) {
      return schoolRole(schoolId) == 'PARENT'
        && exists(/databases/$(database)/documents/schools/$(schoolId)/parent_links/$(request.auth.uid + '_' + studentUid));
    }

    function immutableOnUpdate(fieldName) {
      return resource == null
        || !(fieldName in resource.data)
        || !(fieldName in request.resource.data)
        || request.resource.data[fieldName] == resource.data[fieldName];
    }

    function idMatches(fieldName, expectedId) {
      return !(fieldName in request.resource.data) || request.resource.data[fieldName] == expectedId;
    }

    function hasValidMarkRange() {
      return !('marks' in request.resource.data)
        || (
          request.resource.data.marks is number
          && request.resource.data.marks >= 0
          && request.resource.data.marks <= 100
          && (
            !('maxMarks' in request.resource.data)
            || (
              request.resource.data.maxMarks is number
              && request.resource.data.maxMarks > 0
              && request.resource.data.maxMarks <= 100
              && request.resource.data.marks <= request.resource.data.maxMarks
            )
          )
        );
    }

    function hasValidAttendanceRange() {
      return !('attendancePercentage' in request.resource.data)
        || (
          request.resource.data.attendancePercentage is number
          && request.resource.data.attendancePercentage >= 0
          && request.resource.data.attendancePercentage <= 100
        );
    }

    function hasValidAttendanceCounts() {
      return !('sessionsPresent' in request.resource.data)
        || !('sessionsTotal' in request.resource.data)
        || (
          request.resource.data.sessionsPresent is int
          && request.resource.data.sessionsTotal is int
          && request.resource.data.sessionsPresent >= 0
          && request.resource.data.sessionsTotal >= 0
          && request.resource.data.sessionsPresent <= request.resource.data.sessionsTotal
        );
    }

    function isValidResultStatus(status) {
      return status in ['DRAFT', 'PUBLISHED', 'FINALIZED'];
    }

    function isAllowedResultStatusTransition(fromStatus, toStatus) {
      return toStatus == fromStatus
        || (fromStatus == 'DRAFT' && toStatus in ['PUBLISHED', 'FINALIZED'])
        || (fromStatus == 'PUBLISHED' && toStatus == 'FINALIZED');
    }

    function hasValidResultStatusTransition() {
      return !('status' in request.resource.data)
        || (
          isValidResultStatus(request.resource.data.status)
          && (
            resource == null
            || !('status' in resource.data)
            || isAllowedResultStatusTransition(resource.data.status, request.resource.data.status)
          )
        );
    }

    function isValidAttendanceStatus(status) {
      return status in ['PRESENT', 'ABSENT', 'LATE', 'EXCUSED'];
    }

    function hasValidAttendanceStatusTransition() {
      return !('status' in request.resource.data)
        || (
          isValidAttendanceStatus(request.resource.data.status)
          && (
            resource == null
            || !('status' in resource.data)
            || resource.data.status in ['ABSENT', 'LATE']
            || request.resource.data.status == resource.data.status
          )
        );
    }

    // Global profile map with school memberships.
    match /users/{uid} {
      allow read: if isActive() && (request.auth.uid == uid || isSuperAdmin());
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin()
                    || (request.auth.uid == uid
                        && request.resource.data.role == resource.data.role
                        && request.resource.data.isActive == resource.data.isActive
                        && request.resource.data.schoolMemberships == resource.data.schoolMemberships);
      allow delete: if isSuperAdmin();
    }

    match /schools/{schoolId} {
      allow read: if isSchoolMember(schoolId);
      allow write: if canManageSchool(schoolId);

      match /students/{studentId} {
        allow read: if canReadSchoolPath(schoolId, 'students');
        allow create, update, delete: if canManageSchool(schoolId)
          && idMatches('studentId', studentId)
          && immutableOnUpdate('studentId');
      }

      match /teachers/{teacherId} {
        allow read: if canReadSchoolPath(schoolId, 'teachers');
        allow create, update, delete: if canManageSchool(schoolId)
          && idMatches('teacherId', teacherId)
          && immutableOnUpdate('teacherId');
      }

      match /staff/{staffId} {
        allow read: if canReadSchoolPath(schoolId, 'staff');
        allow create, update, delete: if canManageSchool(schoolId)
          && idMatches('staffId', staffId)
          && immutableOnUpdate('staffId');
      }

      match /classes/{classId} {
        allow read: if canReadSchoolPath(schoolId, 'classes');
        allow create, update, delete: if canManageSchool(schoolId)
          && idMatches('classId', classId)
          && immutableOnUpdate('classId');
      }

      match /attendance/{attendanceId} {
        allow read: if canReadSchoolPath(schoolId, 'attendance');
        allow create, update, delete: if canWriteAcademicRecords(schoolId)
          && idMatches('attendanceId', attendanceId)
          && immutableOnUpdate('attendanceId')
          && hasValidAttendanceRange()
          && hasValidAttendanceCounts()
          && hasValidAttendanceStatusTransition();
      }

      match /homework/{homeworkId} {
        allow read: if canReadSchoolPath(schoolId, 'homework');
        allow create, update, delete: if canWriteAcademicRecords(schoolId)
          && idMatches('homeworkId', homeworkId)
          && immutableOnUpdate('homeworkId');

        match /submissions/{submissionId} {
          allow read: if canWriteAcademicRecords(schoolId)
            || request.auth.uid == submissionId
            || isParentLinkedToStudent(schoolId, submissionId);
          allow create, update: if request.auth.uid == submissionId
            || canWriteAcademicRecords(schoolId);
          allow delete: if canWriteAcademicRecords(schoolId);
        }
      }

      match /results/{resultId} {
        allow read: if canReadSchoolPath(schoolId, 'results');
        allow create, update, delete: if canWriteAcademicRecords(schoolId)
          && idMatches('resultId', resultId)
          && immutableOnUpdate('resultId')
          && hasValidMarkRange()
          && hasValidResultStatusTransition();
      }

      match /announcements/{announcementId} {
        allow read: if canReadSchoolPath(schoolId, 'announcements');
        allow create, update, delete: if canManageSchool(schoolId)
          && idMatches('announcementId', announcementId)
          && immutableOnUpdate('announcementId');
      }

      match /parent_links/{linkId} {
        allow read: if canManageSchool(schoolId) || schoolRole(schoolId) == 'PARENT';
        allow create, update, delete: if canManageSchool(schoolId);
      }

      // Denormalized read models for dashboard cards.
      match /read_models/{modelId} {
        allow read: if canReadSchoolPath(schoolId, 'read_models');
        allow create, update, delete: if canManageSchool(schoolId);

        match /dashboard_cards/{cardId} {
          allow read: if canReadSchoolPath(schoolId, 'read_models');
          allow create, update, delete: if canManageSchool(schoolId);
        }
      }

      // Sensitive collections are backend-controlled only.
      match /results_finalization/{docId} {
        allow read: if canReadSchoolPath(schoolId, 'results_finalization');
        allow write: if false;
      }

      match /payroll/{docId} {
        allow read: if canManageSchool(schoolId);
        allow write: if false;
      }

      match /critical_attendance_overrides/{docId} {
        allow read: if canManageSchool(schoolId);
        allow write: if false;
      }

      match /notification_queue/{notificationId} {
        allow read: if canManageSchool(schoolId) || request.auth.uid == resource.data.studentUid;
        allow write: if false;
      }
    }

    // Only management/super-admin can write audit logs.
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }
  }
}
